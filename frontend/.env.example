# Base URL of the FastAPI backend (the Render service URL in production).
# Exposed to the browser for the /health probe, and used server-side by the
# /api/analyze proxy route as the default backend target.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional server-only override for the /api/analyze proxy target. When set it
# takes precedence over NEXT_PUBLIC_API_URL, keeping the backend URL off the
# client if you ever want it private. Falls back to NEXT_PUBLIC_API_URL.
# API_URL=http://localhost:8000
