# Base URL of the FastAPI backend (the Render service URL in production).
# The browser posts swing uploads directly to ${NEXT_PUBLIC_API_URL}/analyze
# (not through a Next.js proxy — a Vercel serverless function would cap the body
# at ~4.5MB, but the UI allows up to 50MB). Also used for the /health probe.
NEXT_PUBLIC_API_URL=http://localhost:8000
