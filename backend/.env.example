# Comma-separated list of origins allowed to call this API via CORS.
# In production set this to the deployed Vercel frontend URL.
ALLOWED_ORIGINS=http://localhost:3000

# Production guardrails (optional — sensible code defaults apply if unset).
# Largest upload accepted before the API returns 413 (bytes). Default 50MB,
# matching the limit the frontend advertises.
MAX_UPLOAD_BYTES=52428800
# Wall-clock budget for the CPU-bound validation + detection path, in seconds.
# A request that exceeds it returns 504. Default 60.
MAX_ANALYSIS_SECONDS=60
